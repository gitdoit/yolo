# Python 编译产物
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
.venv/
env/


# 模型权重文件（通常几十到几百MB，不提交到git）
models/*.pt
models/*.onnx
models/*.engine

# 检测结果输出（可随时重新生成）
outputs/

# 测试视频（通常较大）
data/videos/*.mp4
data/videos/*.avi

# Jupyter Notebook 检查点
.ipynb_checkpoints/

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# Ultralytics 运行产物
runs/
/datasets/
